{
    "function_name": "MTF-PPST",
    "description": "Multi-Timeframe Pivot Point SuperTrend strategy for analyzing trends across multiple timeframes",
    "financial_data_keys": [],
    "call_arguments_schema": {
        "type": "object",
        "properties": {
            "ppstConfigs": {
                "type": "array",
                "description": "Array of PPST configurations for different timeframes",
                "default": [
                    {
                        "pivot_point_period": 12,
                        "atr_factor": 3.0,
                        "atr_period": 14,
                        "timeframe": "1m",
                        "candles_key": "1m-key"
                    }
                ],
                "items": {
                    "type": "object",
                    "properties": {
                        "pivot_point_period": {
                            "type": "integer",
                            "description": "Period for pivot point detection (recommended: 10-15)",
                            "minimum": 1,
                            "default": 12
                        },
                        "atr_factor": {
                            "type": "number",
                            "description": "ATR multiplier for SuperTrend bands (recommended: 2.0-3.5)",
                            "minimum": 0,
                            "default": 3.0
                        },
                        "atr_period": {
                            "type": "integer",
                            "description": "Period for ATR calculation (recommended: 14)",
                            "minimum": 1,
                            "default": 14
                        },
                        "timeframe": {
                            "type": "string",
                            "enum": ["1m", "5m", "15m", "30m", "1h", "4h", "1d"],
                            "description": "Timeframe for the strategy",
                            "default": "1m"
                        },
                        "candles_key": {
                            "type": "string",
                            "description": "Key used in financial data as key for this strategy (the timeframe must match)"
                        }
                    },
                    "required": ["pivot_point_period", "atr_factor", "atr_period", "timeframe", "candles_key"]
                },
                "minItems": 1
            }
        },
        "required": ["ppstConfigs"]
    },
    "enforce_schemas": true
}